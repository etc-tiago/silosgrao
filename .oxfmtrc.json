{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".vscode",
    "worker-configuration.d.ts",
    "src/routeTree.gen.ts",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "bun.lock"
  ],
  "sortTailwindcss": {
    "stylesheet": "src/styles.css",
    "functions": ["cn", "cva"]
  }
}
