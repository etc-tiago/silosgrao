{
  "name": "site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint .",
    "format": "oxfmt",
    "check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "db:setup:local": "wrangler d1 execute silosgraos-cms --local --file=src/db/schema.sql && wrangler d1 execute silosgraos-cms --local --file=src/db/seed.sql",
    "db:setup:remote": "wrangler d1 execute silosgraos-cms --remote --file=src/db/schema.sql && wrangler d1 execute silosgraos-cms --remote --file=src/db/seed.sql",
    "cf:types": "wrangler types",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@marsidev/react-turnstile": "^1.5.3",
    "@noble/hashes": "^2.2.0",
    "@orpc/client": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.72.0",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4",
    "wrangler": "^4.107.0"
  }
}
