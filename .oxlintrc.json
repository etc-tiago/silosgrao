{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import", "unicorn", "oxc"],
  "env": {
    "browser": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "worker-configuration.d.ts",
    "src/routeTree.gen.ts"
  ],
  "rules": {
    "import/no-cycle": "off"
  }
}
